<script>
  /* ── Donde form AJAX ── */
  const dondeForm = document.getElementById('dondeForm');
  if (dondeForm) {
    dondeForm.addEventListener('submit', function(e) {
      e.preventDefault();
      const btn = dondeForm.querySelector('button[type="submit"]');
      btn.disabled = true;
      btn.textContent = 'Enviando...';
      fetch(dondeForm.action, {
        method: 'POST',
        body: new FormData(dondeForm),
        headers: { 'Accept': 'application/json' }
      }).then(r => {
        if (r.ok) {
          dondeForm.style.display = 'none';
          document.getElementById('dondeFormSuccess').style.display = 'block';
        } else {
          btn.disabled = false;
          btn.textContent = 'Enviar mensaje';
        }
      }).catch(() => {
        btn.disabled = false;
        btn.textContent = 'Enviar mensaje';
      });
    });
  }

  /* ── Lead form AJAX (evitar redirect a Formspree) ── */
  const leadForm = document.getElementById('leadForm');
  const leadMsg  = document.getElementById('leadFormMsg');
  if (leadForm) {
    leadForm.addEventListener('submit', function(e) {
      e.preventDefault();
      const btn = leadForm.querySelector('button[type="submit"]');
      btn.disabled = true;
      btn.textContent = 'Enviando...';
      fetch(leadForm.action, {
        method: 'POST',
        body: new FormData(leadForm),
        headers: { 'Accept': 'application/json' }
      }).then(r => {
        if (r.ok) {
          leadForm.style.display = 'none';
          leadMsg.style.display = 'block';
        } else {
          btn.disabled = false;
          btn.textContent = 'Solicitar cita';
          alert('Error al enviar. Llámanos al 656 306 167.');
        }
      }).catch(() => {
        btn.disabled = false;
        btn.textContent = 'Solicitar cita';
        alert('Error al enviar. Llámanos al 656 306 167.');
      });
    });
  }

  /* ── Video: cargar tras window.load (no bloquea LCP) ── */
  const video = document.querySelector('.hero-video[data-src]');
  const heroPoster = document.querySelector('.hero-poster');
  window.addEventListener('load', () => {
    if (!video) return;
    setTimeout(() => {
      const source = document.createElement('source');
      source.src = video.dataset.src;
      source.type = 'video/mp4';
      video.appendChild(source);
      video.load();
      video.play().catch(() => {});
      video.addEventListener('playing', () => {
        video.style.opacity = '0.92';
        if (heroPoster) heroPoster.classList.add('hidden');
      }, { once: true });
    }, 800);
  });

  /* ── Video sound toggle ── */
  const soundBtn = document.getElementById('soundToggle');
  if (video && soundBtn) {
    soundBtn.addEventListener('click', () => {
      video.muted = !video.muted;
      soundBtn.querySelector('.icon-muted').style.display = video.muted ? '' : 'none';
      soundBtn.querySelector('.icon-sound').style.display = video.muted ? 'none' : '';
    });
  }

</script>

