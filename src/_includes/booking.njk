    pickDay: "Elige tu plaza",
    noSlots: "Sin plazas este día",
    scarcityNote: "Agenda limitada para atención personalizada",
    formName: "Nombre",
    formPhone: "Teléfono",
    formTreatment: "¿Qué tratamiento te interesa?",
    formNotes: "Notas (opcional)",
    submit: "Reservar cita y avisar por WhatsApp",
    submitHint: "Abriremos WhatsApp con tu reserva escrita. AnyLopez te confirma en menos de 2 h.",
    success: "Hemos recibido tu reserva. AnyLopez te confirma por WhatsApp en menos de 2 h (horario de clínica).",
    error: "No hemos podido cargar la disponibilidad. Llámanos al +34 656 306 167 o usa WhatsApp.",
    fallbackHref: "https://wa.me/34656306167",
    fallbackText: "Escríbenos por WhatsApp",
    consultation: "Consulta gratuita personalizada",
    starLabel: "Tratamiento estrella",
    star: "INDIBA Activ · Programa anti-edad facial y corporal",
    groupLabel: "Por objetivo",
    groups: [
      "Verme más joven y firme (lifting y antiaging)",
      "Suavizar arrugas y recuperar volumen (Botox y rellenos)",
      "Mejorar mi piel y luminosidad (faciales, dermapen, peelings)",
      "Tratamientos corporales y reducción",
      "Otros (depilación, estética decorativa, masajes)"
    ],
    other: "No estoy segura — recomiéndame"
  },
  en: {
    title: "Book your free consultation",
    subtitle: "30 minutes · personalised diagnosis · no commitment",
    prevMonth: "Previous month",
    nextMonth: "Next month",
    weekdays: ["M", "T", "W", "T", "F", "S", "S"],
    pickDay: "Pick your slot",
    noSlots: "No slots this day",
    scarcityNote: "Limited availability for personalised attention",
    formName: "Name",
    formPhone: "Phone",
    formTreatment: "Which treatment interests you?",
    formNotes: "Notes (optional)",
    submit: "Book and notify via WhatsApp",
    submitHint: "We'll open WhatsApp with your booking written. AnyLopez confirms within 2 h.",
    success: "We've received your booking. AnyLopez will confirm via WhatsApp within 2 h (clinic hours).",
    error: "We couldn't load availability. Call us at +34 656 306 167 or use WhatsApp.",
    fallbackHref: "https://wa.me/34656306167",
    fallbackText: "Message us on WhatsApp",
    consultation: "Free personalised consultation",
    starLabel: "Featured treatment",
    star: "INDIBA Activ · Flagship anti-ageing programme",
    groupLabel: "By goal",
    groups: [
      "Younger and firmer skin (lifting & anti-ageing)",
