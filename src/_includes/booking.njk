<section class="booking-section" id="booking"
  data-api="https://anylopez-booking-worker.anylopez.workers.dev/booking/availability"
  data-formspree="xrerbgdw"
  data-wa="34656306167">
  <div class="booking-container">
    <header class="booking-header">
      <h2>{{ L.title }}</h2>
      <p class="booking-subtitle">{{ L.subtitle }}</p>
      <p class="booking-scarcity-note">{{ L.scarcityNote }}</p>
    </header>

    <div class="booking-body" hidden>
      <div class="booking-calendar">
        <div class="booking-month-nav">
          <button class="booking-nav-btn" data-action="prev" aria-label="{{ L.prevMonth }}">◀</button>
          <h3 class="booking-month-label" data-bind="month-label"></h3>
          <button class="booking-nav-btn" data-action="next" aria-label="{{ L.nextMonth }}">▶</button>
        </div>
        <div class="booking-weekdays">
          {% for d in L.weekdays %}<span>{{ d }}</span>{% endfor %}
        </div>
        <div class="booking-days" data-bind="days"></div>
      </div>

      <aside class="booking-slots">
        <h4 data-bind="day-label">{{ L.pickDay }}</h4>
        <ul class="booking-slot-list" data-bind="slots"></ul>
        <p class="booking-no-slots" data-bind="no-slots" hidden>{{ L.noSlots }}</p>
      </aside>
    </div>

    <div class="booking-loading" data-bind="loading">
      <span class="booking-spinner"></span>
    </div>

    <div class="booking-error" data-bind="error" hidden>
      <p>{{ L.error }}</p>
      <a href="{{ L.fallbackHref }}" class="booking-fallback-cta">{{ L.fallbackText }}</a>
    </div>
  </div>

  <dialog class="booking-modal" data-bind="modal">
    <form class="booking-form" data-bind="form">
      <h3 data-bind="modal-title"></h3>
      <input type="hidden" name="slot" data-bind="form-slot">
      <label>
        <span>{{ L.formName }}</span>
        <input type="text" name="name" required minlength="2">
      </label>
      <label>
        <span>{{ L.formPhone }}</span>
        <input type="tel" name="phone" required pattern="[0-9 +\-]{6,}">
      </label>
      <label>
        <span>{{ L.formTreatment }}</span>
        <select name="treatment" required>
          <option value="" disabled selected></option>
          <option value="{{ L.consultation }}">{{ L.consultation }}</option>
          <optgroup label="{{ L.starLabel }}">
            <option value="{{ L.star }}">{{ L.star }}</option>
          </optgroup>
          <optgroup label="{{ L.groupLabel }}">
            {% for t in L.groups %}<option value="{{ t }}">{{ t }}</option>{% endfor %}
          </optgroup>
          <option value="{{ L.other }}">{{ L.other }}</option>
        </select>
      </label>
      <label>
        <span>{{ L.formNotes }}</span>
        <textarea name="notes" maxlength="300" rows="2"></textarea>
      </label>
      <div class="booking-form-actions">
        <button type="button" class="booking-btn-cancel" data-action="cancel">✕</button>
        <button type="submit" class="booking-btn-submit" aria-describedby="booking-submit-hint">{{ L.submit }}</button>
      </div>
      <p id="booking-submit-hint" class="booking-submit-hint">{{ L.submitHint }}</p>
    </form>
    <p class="booking-success" data-bind="success" hidden>{{ L.success }}</p>
  </dialog>
</section>

<script>
  window.__BOOKING_LANG__ = "{{ lang }}";
  window.__BOOKING_TXT__ = {{ L | dump | safe }};
</script>
<link rel="stylesheet" href="{{ '/css/booking.css' | url }}">
<script src="{{ '/js/booking.js' | url }}" defer></script>
