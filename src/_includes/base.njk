<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="{{ description }}" />
  <title>{{ title }}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preconnect" href="https://anylopez.com" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Brygada+1918:ital,wght@0,400;0,600;1,400&family=Inter:wght@300;400;500;600&display=swap" />
  {% if preloadHero %}
  <link rel="preload" as="image" href="https://anylopez.com/wp-content/uploads/2024/08/fondo-web.png" />
  {% endif %}
  <link rel="stylesheet" href="{{ '/css/styles.css' | url }}" />
</head>
<body>

  <!-- HEADER -->
  <header class="site-header" id="siteHeader">
    <div class="header-inner">
      <a href="{{ '/' | url }}" class="logo" aria-label="AnyLopez Clínica Estética">
        <img src="{{ '/images/logo.png' | url }}" alt="AnyLopez Clínica Estética" class="logo-img" width="110" height="110" fetchpriority="high" />
      </a>
      <nav>
        <ul class="nav-menu" id="navMenu">
          <li><a href="{{ '/' | url }}" class="{{ 'active' if page.url == '/' }}">Inicio</a></li>
          <li><a href="{{ '/about/' | url }}" class="{{ 'active' if page.url == '/about/' }}">Nosotros</a></li>
          <li><a href="{{ '/services/' | url }}" class="{{ 'active' if page.url == '/services/' }}">Servicios</a></li>
          <li><a href="{{ '/radiofrecuencia/' | url }}" class="{{ 'active' if page.url == '/radiofrecuencia/' }}">Indiba</a></li>
          <li><a href="{{ '/contact/' | url }}" class="{{ 'active' if page.url == '/contact/' }}">Contacto</a></li>
          <li class="nav-cta"><a href="{{ '/contact/' | url }}" class="btn btn-accent">Reserva tu Cita</a></li>
        </ul>
        <button class="menu-toggle" id="menuToggle" aria-label="Abrir menú">
          <span></span><span></span><span></span>
        </button>
      </nav>
    </div>
  </header>

  {{ content | safe }}

  <!-- FOOTER -->
  <footer class="site-footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-brand">
          <a href="{{ '/' | url }}" class="logo">Any<span style="color:var(--accent)">Lopez</span></a>
          <p>Clínica estética facial y corporal en Benidorm. Tratamientos personalizados con tecnología de última generación y más de 35 años de experiencia.</p>
          <div class="social-links">
            <a href="#" class="social-link" aria-label="Instagram">📷</a>
            <a href="#" class="social-link" aria-label="Facebook">📘</a>
            <a href="#" class="social-link" aria-label="WhatsApp">💬</a>
          </div>
        </div>
        <div class="footer-col">
          <h4>Navegación</h4>
          <ul>
            <li><a href="{{ '/' | url }}">Inicio</a></li>
            <li><a href="{{ '/about/' | url }}">Nosotros</a></li>
            <li><a href="{{ '/services/' | url }}">Servicios</a></li>
            <li><a href="{{ '/radiofrecuencia/' | url }}">Indiba</a></li>
            <li><a href="{{ '/contact/' | url }}">Contacto</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>Servicios</h4>
          <ul>
            <li><a href="{{ '/services/' | url }}">Higienes Faciales</a></li>
            <li><a href="{{ '/services/' | url }}">Radiofrecuencia</a></li>
            <li><a href="{{ '/services/' | url }}">Ultherapy</a></li>
            <li><a href="{{ '/services/' | url }}">Dermapen</a></li>
            <li><a href="{{ '/services/' | url }}">Botox</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>Contacto</h4>
          <p>📍 C/ Marqués de Comillas 4, Local 6, Benidorm</p>
          <p>📞 656 306 167</p>
          <p>📞 865 710 769</p>
          <p>✉️ info@anylopez.com</p>
          <p>🕐 Lun–Vie: 10–14h / 16–20h</p>
        </div>
      </div>
      <div class="footer-bottom">
        <p>© 2024 AnyLopez Clínica Estética. Todos los derechos reservados.</p>
      </div>
    </div>
  </footer>

  <script>
    const toggle = document.getElementById('menuToggle');
    const menu   = document.getElementById('navMenu');
    toggle.addEventListener('click', () => menu.classList.toggle('open'));
    menu.querySelectorAll('a').forEach(a => a.addEventListener('click', () => menu.classList.remove('open')));

    /* Reviews Spotlight */
    (function() {
      const carousel = document.getElementById('reviewsCarousel');
      if (!carousel) return;
      const prev = document.querySelector('.carousel-prev');
      const next = document.querySelector('.carousel-next');
      const dotsContainer = document.getElementById('carouselDots');
      const cards = carousel.querySelectorAll('.testimonial');
      const AUTOPLAY_DELAY = 5000;
      let autoplayTimer = null;
      let currentIndex = 0;
      const total = cards.length;

      const goTo = (index) => {
        currentIndex = (index + total) % total;
        cards.forEach((c, i) => c.classList.toggle('is-active', i === currentIndex));
        dotsContainer.querySelectorAll('.carousel-dot').forEach((d, i) =>
          d.classList.toggle('active', i === currentIndex)
        );
      };

      cards.forEach((_, i) => {
        const dot = document.createElement('button');
        dot.className = 'carousel-dot' + (i === 0 ? ' active' : '');
        dot.setAttribute('aria-label', 'Reseña ' + (i + 1));
        dotsContainer.appendChild(dot);
        dot.addEventListener('click', () => { goTo(i); resetAutoplay(); });
      });

      prev.addEventListener('click', () => { goTo(currentIndex - 1); resetAutoplay(); });
      next.addEventListener('click', () => { goTo(currentIndex + 1); resetAutoplay(); });

      const startAutoplay = () => {
        autoplayTimer = setInterval(() => goTo(currentIndex + 1), AUTOPLAY_DELAY);
      };

      const resetAutoplay = () => {
        clearInterval(autoplayTimer);
        startAutoplay();
      };

      /* Pausa al hover o touch */
      carousel.addEventListener('mouseenter', () => clearInterval(autoplayTimer));
      carousel.addEventListener('mouseleave', startAutoplay);
      carousel.addEventListener('touchstart', () => clearInterval(autoplayTimer), { passive: true });
      carousel.addEventListener('touchend', resetAutoplay, { passive: true });

      startAutoplay();
    })();
  </script>
</body>
</html>
