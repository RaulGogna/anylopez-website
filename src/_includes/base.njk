<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="{{ description }}" />
  <title>{{ title }}</title>
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body>

  <!-- HEADER -->
  <header class="site-header">
    <div class="header-inner">
      <a href="/" class="logo">Any<span>Lopez</span></a>
      <nav>
        <ul class="nav-menu" id="navMenu">
          <li><a href="/" class="{{ 'active' if page.url == '/' }}">Inicio</a></li>
          <li><a href="/about/" class="{{ 'active' if page.url == '/about/' }}">Nosotros</a></li>
          <li><a href="/services/" class="{{ 'active' if page.url == '/services/' }}">Servicios</a></li>
          <li><a href="/radiofrecuencia/" class="{{ 'active' if page.url == '/radiofrecuencia/' }}">Indiba</a></li>
          <li><a href="/contact/" class="{{ 'active' if page.url == '/contact/' }}">Contacto</a></li>
          <li class="nav-cta"><a href="/contact/" class="btn btn-primary">Reserva tu Cita</a></li>
        </ul>
        <button class="menu-toggle" id="menuToggle" aria-label="Abrir menú">
          <span></span><span></span><span></span>
        </button>
      </nav>
    </div>
  </header>

  {{ content | safe }}

  <!-- FOOTER -->
  <footer class="site-footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-brand">
          <a href="/" class="logo">Any<span style="color:var(--accent)">Lopez</span></a>
          <p>Clínica estética facial y corporal en Benidorm. Tratamientos personalizados con tecnología de última generación y más de 35 años de experiencia.</p>
          <div class="social-links">
            <a href="#" class="social-link" aria-label="Instagram">📷</a>
            <a href="#" class="social-link" aria-label="Facebook">📘</a>
            <a href="#" class="social-link" aria-label="WhatsApp">💬</a>
          </div>
        </div>
        <div class="footer-col">
          <h4>Navegación</h4>
          <ul>
            <li><a href="/">Inicio</a></li>
            <li><a href="/about/">Nosotros</a></li>
            <li><a href="/services/">Servicios</a></li>
            <li><a href="/radiofrecuencia/">Indiba</a></li>
            <li><a href="/contact/">Contacto</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>Servicios</h4>
          <ul>
            <li><a href="/services/">Higienes Faciales</a></li>
            <li><a href="/services/">Radiofrecuencia</a></li>
            <li><a href="/services/">Ultherapy</a></li>
            <li><a href="/services/">Dermapen</a></li>
            <li><a href="/services/">Botox</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>Contacto</h4>
          <p>📍 C/ Marqués de Comillas 4, Local 6, Benidorm</p>
          <p>📞 656 306 167</p>
          <p>📞 865 710 769</p>
          <p>✉️ info@anylopez.com</p>
          <p>🕐 Lun–Vie: 10–14h / 16–20h</p>
        </div>
      </div>
      <div class="footer-bottom">
        <p>© 2024 AnyLopez Clínica Estética. Todos los derechos reservados.</p>
      </div>
    </div>
  </footer>

  <script>
    const toggle = document.getElementById('menuToggle');
    const menu   = document.getElementById('navMenu');
    toggle.addEventListener('click', () => menu.classList.toggle('open'));
    menu.querySelectorAll('a').forEach(a => a.addEventListener('click', () => menu.classList.remove('open')));
  </script>
</body>
</html>
