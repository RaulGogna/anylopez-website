# anylopez.com — Hostalia Apache config
# Headers de seguridad + cache + compresión

<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json application/xml image/svg+xml
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 1 hour"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/webp "access plus 6 months"
  ExpiresByType image/png "access plus 6 months"
  ExpiresByType image/jpeg "access plus 6 months"
  ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# Force HTTPS (por si Hostalia no lo hace en panel)
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTPS} !=on
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Canonicalización www → non-www
  RewriteCond %{HTTP_HOST} ^www\.anylopez\.com$ [NC]
  RewriteRule ^ https://anylopez.com%{REQUEST_URI} [L,R=301]

  # Fantasma del WordPress viejo: /es/ raíz → home (el español vive en /)
  RewriteRule ^es/?$ / [R=301,L]
</IfModule>
