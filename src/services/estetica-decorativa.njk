<script>
  document.querySelectorAll('.cat-page-faq-q').forEach((btn) => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.cat-page-faq-item');
      const wasOpen = item.classList.contains('open');
      document.querySelectorAll('.cat-page-faq-item').forEach((i) => i.classList.remove('open'));
      if (!wasOpen) item.classList.add('open');
    });
  });
</script>
