---
layout: base.njk
title: "Aesthetic Treatments at AnyLopez Clinic — Benidorm"
description: "Eight specialities, one craft. Editorial catalogue of facial, body, injectable and apparatology treatments at AnyLopez Aesthetic Clinic, Benidorm."
---

<style>
  /* ─── HERO ─────────────────────────────────────────── */
  .svc-hero {
    padding: 96px 0 72px;
    background: var(--ivory);
    text-align: center;
  }
  .svc-hero h1 {
    font-size: clamp(40px, 6.5vw, 76px);
    line-height: 1.05;
    margin: 12px auto 24px;
    max-width: 880px;
    letter-spacing: -0.01em;
  }
  .svc-hero h1 em {
    font-style: italic;
    color: var(--terra);
  }
  .svc-hero p.lead {
    font-size: clamp(16px, 2vw, 19px);
    color: var(--text-mid);
    max-width: 620px;
    margin: 0 auto 36px;
    line-height: 1.6;
  }
  .svc-hero-meta {
    display: inline-flex;
    align-items: center;
    gap: 18px;
    flex-wrap: wrap;
    justify-content: center;
    font-size: 13px;
    color: var(--text-mid);
    margin-top: 28px;
  }
  .svc-hero-meta strong { color: var(--text); font-weight: 600; }
  .svc-hero-meta span.dot { color: var(--sand-mid); }
  .svc-hero-stars { color: var(--gold); letter-spacing: 1px; font-size: 15px; }

  /* ─── INDEX GRID ──────────────────────────────────── */
  .svc-index {
    padding: 24px 0 96px;
    background: var(--ivory);
  }
  .svc-index-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 32px;
  }

  /* ─── CATEGORY CARD (editorial) ───────────────────── */
  .svc-cat {
    position: relative;
    display: block;
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 2px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: transform 0.4s var(--ease), box-shadow 0.4s var(--ease), border-color 0.4s var(--ease);
  }
  /* PERF: aplazar layout/paint de las tarjetas below-fold. Las 2 primeras
     quedan above-fold en mobile (viewport ~640px, card ~574px). */
  .svc-cat:nth-child(n+3) {
    content-visibility: auto;
    contain-intrinsic-size: auto 574px;
  }
  .svc-cat:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-lg);
    border-color: var(--terra);
  }
  .svc-cat-img {
    position: relative;
    height: 280px;
    overflow: hidden;
  }
  .svc-cat-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s var(--ease);
  }
  .svc-cat:hover .svc-cat-img img { transform: scale(1.04); }
  .svc-cat-img::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(26,18,8,0) 0%, rgba(26,18,8,0.45) 100%);
  }
  .svc-cat-num {
    position: absolute;
    top: 20px;
    left: 24px;
    z-index: 2;
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,0.85);
  }
  .svc-cat-flag {
    position: absolute;
    top: 20px;
    right: 24px;
    z-index: 2;
    background: var(--terra);
    color: #fff;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 6px 12px;
    border-radius: 2px;
  }
  .svc-cat-body {
    padding: 32px 32px 36px;
  }
  .svc-cat-eyebrow {
    font-family: 'Jost', sans-serif;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--terra);
    margin-bottom: 12px;
    display: block;
  }
  .svc-cat-name {
    font-size: clamp(24px, 3vw, 32px);
    line-height: 1.15;
    margin-bottom: 14px;
    color: var(--dark);
  }
  .svc-cat-desc {
    font-size: 15px;
    line-height: 1.6;
    color: var(--text-mid);
    margin-bottom: 20px;
  }
  .svc-cat-trat-list {
    font-size: 13px;
    color: var(--text-light);
    line-height: 1.6;
    margin-bottom: 24px;
  }
  .svc-cat-cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--terra-dk);
    border-bottom: 1px solid currentColor;
    padding-bottom: 4px;
    transition: gap 0.25s var(--ease), color 0.25s var(--ease);
  }
  .svc-cat:hover .svc-cat-cta {
    gap: 14px;
    color: var(--terra);
  }

  /* ─── FLAGSHIP BAND (INDIBA) ──────────────────────── */
  .svc-flagship {
    background: var(--dark);
    color: #fff;
    padding: 96px 0;
    position: relative;
    overflow: hidden;
  }
  .svc-flagship-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }
  .svc-flagship-img {
    border-radius: 2px;
    overflow: hidden;
    position: relative;
    aspect-ratio: 4 / 5;
  }
  .svc-flagship-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .svc-flagship h2 {
    color: #fff;
    font-size: clamp(34px, 4.5vw, 56px);
    line-height: 1.05;
    margin-bottom: 24px;
  }
  .svc-flagship h2 em {
    font-style: italic;
    color: var(--gold);
  }
  .svc-flagship p {
    font-size: 17px;
    color: rgba(255,255,255,0.78);
    line-height: 1.65;
    margin-bottom: 28px;
  }
  .svc-flagship-meta {
    display: flex;
    gap: 32px;
    flex-wrap: wrap;
    margin-bottom: 32px;
    padding-top: 24px;
    border-top: 1px solid rgba(255,255,255,0.12);
  }
  .svc-flagship-meta-item {
    font-size: 13px;
    color: rgba(255,255,255,0.7);
  }
  .svc-flagship-meta-item strong {
    display: block;
    color: var(--gold);
    font-family: 'Cormorant Garamond', serif;
    font-size: 28px;
    font-weight: 500;
    margin-bottom: 4px;
  }

  /* ─── TRUST STRIP ─────────────────────────────────── */
  .svc-trust {
    background: var(--sand);
    padding: 56px 0;
    text-align: center;
  }
  .svc-trust-stars { color: var(--gold); font-size: 22px; letter-spacing: 2px; margin-bottom: 12px; }
  .svc-trust-rating {
    font-family: 'Cormorant Garamond', serif;
    font-size: 32px;
    font-weight: 500;
    color: var(--dark);
    margin-bottom: 6px;
  }
  .svc-trust-rating strong { color: var(--terra); font-weight: 500; }
  .svc-trust-sub { font-size: 13px; color: var(--text-mid); letter-spacing: 0.04em; }

  /* ─── FINAL CTA ───────────────────────────────────── */
  .svc-final-cta {
    padding: 120px 0;
    text-align: center;
    background: var(--ivory);
  }
  .svc-final-cta h2 {
    font-size: clamp(32px, 4.5vw, 52px);
    line-height: 1.1;
    max-width: 720px;
    margin: 0 auto 20px;
  }
  .svc-final-cta p {
    font-size: 17px;
    color: var(--text-mid);
    max-width: 540px;
    margin: 0 auto 36px;
  }
  .svc-final-cta-row {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* ─── RESPONSIVE ──────────────────────────────────── */
  @media (max-width: 900px) {
    .svc-index-grid { grid-template-columns: 1fr; gap: 24px; }
    .svc-flagship-grid { grid-template-columns: 1fr; gap: 40px; }
    .svc-flagship-img { aspect-ratio: 16/10; }
    .svc-cat-img { height: 220px; }
    .svc-cat-body { padding: 24px 24px 28px; }
  }
  @media (max-width: 640px) {
    .svc-hero { padding: 64px 0 48px; }
    .svc-flagship { padding: 64px 0; }
    .svc-final-cta { padding: 80px 0; }
  }
</style>

<!-- BREADCRUMB -->
<div class="breadcrumb">
  <div class="container">
    <a href="{{ '/en/' | url }}">Home</a>
    <span>›</span>
    <span>Services</span>
  </div>
</div>

<!-- HERO -->
<section class="svc-hero">
  <div class="container">
    <span class="eyebrow">Catalogue · 8 specialities</span>
    <h1>Eight specialities,<br><em>one craft.</em></h1>
    <p class="lead">Three generations designing, delivering and overseeing every treatment. We don't hire trainees or rush back-to-back sessions to fit a tight schedule — when you book, you're seen by the person who signs off the result.</p>
    <div class="svc-hero-meta">
      <span class="svc-hero-stars">★★★★★</span>
      <strong>5.0 from 216 Google reviews</strong>
      <span class="dot">·</span>
      <span>{{ en.tratamientos.tratamientos | length }} treatments available</span>
      <span class="dot">·</span>
      <span>Free initial assessment</span>
    </div>
  </div>
</section>

<!-- INDEX GRID -->
<section class="svc-index">
  <div class="container">
    <div class="svc-index-grid">

      {%- set catImages = {
        "limpiezas-faciales":   { "img": "fotoscatalogoanylopez/limpiezafacial",         "label": "Hygiene + regular care" },
        "tratamientos-faciales":{ "img": "fotoscatalogoanylopez/dermapen",               "label": "Renewal · Anti-acne · Pigmentation" },
        "lifting-antiaging":    { "img": "fotoscatalogoanylopez/ultherapyfacial",        "label": "Non-surgical firming" },
        "inyectables":          { "img": "fotoscatalogoanylopez/rellenoacidohialuronico","label": "Advanced aesthetic medicine" },
        "corporal":             { "img": "tratamientos/maderoterapia",                   "label": "Body · Tone · Recovery" },
        "masajes":              { "img": "tratamientos/masajes",                         "label": "Manual · Therapeutic · Drainage" },
        "estetica-decorativa":  { "img": "tratamientos/micropigmentacion",               "label": "Lashes · Semi-permanent make-up" },
        "depilacion":           { "img": "tratamientos/depilacion-ipl",                  "label": "IPL · Comfortable for sensitive skin" }
      } -%}

      {% for cat in en.tratamientos.categorias %}
        {%- set catTrats = en.tratamientos.tratamientos | byCategory(cat.id) -%}
        {%- set imgInfo = catImages[cat.id] -%}
        {%- set imgPath = imgInfo.img -%}
        {%- set isFlag = cat.id == "lifting-antiaging" -%}
        {%- set padded = "0" + (loop.index | string) if loop.index < 10 else (loop.index | string) -%}
        {%- set total = "0" + (en.tratamientos.categorias | length | string) if (en.tratamientos.categorias | length) < 10 else (en.tratamientos.categorias | length | string) -%}

        <a href="{{ ('/en/services/' + cat.id + '/') | url }}" class="svc-cat" data-cat="{{ cat.id }}">
          <div class="svc-cat-img">
            <span class="svc-cat-num">{{ padded }} / {{ total }}</span>
            {% if isFlag %}<span class="svc-cat-flag">Flagship speciality</span>{% endif %}
            <picture>
              <source srcset="{{ ('/images/' + imgPath + '.webp') | url }}" type="image/webp">
              <img
                src="{{ ('/images/' + imgPath + '.png') | url }}"
                alt="{{ cat.nombre }} at AnyLopez Benidorm"
                loading="{{ 'eager' if loop.index <= 2 else 'lazy' }}"
                decoding="async"
                width="640"
                height="360"
              />
            </picture>
          </div>
          <div class="svc-cat-body">
            <span class="svc-cat-eyebrow">{{ imgInfo.label }}</span>
            <h2 class="svc-cat-name">{{ cat.nombre }}</h2>
            <p class="svc-cat-desc">{{ cat.descripcion }}</p>
            <p class="svc-cat-trat-list">
              {%- set tratNamesStr = "" -%}
              {%- for t in catTrats -%}
                {%- if loop.first -%}
                  {%- set tratNamesStr = t.nombre -%}
                {%- else -%}
                  {%- set tratNamesStr = tratNamesStr + " · " + t.nombre -%}
                {%- endif -%}
              {%- endfor -%}
              {{ catTrats | length }} treatment{{ "s" if catTrats | length > 1 else "" }} ·
              {{ tratNamesStr | truncate(110, true, "…") }}
            </p>
            <span class="svc-cat-cta">View treatments <span aria-hidden="true">→</span></span>
          </div>
        </a>
      {% endfor %}

    </div>
  </div>
</section>

<!-- TRUST STRIP -->
<section class="svc-trust">
  <div class="container">
    <div class="svc-trust-stars">★★★★★</div>
    <div class="svc-trust-rating"><strong>5.0</strong> · 216 verified Google reviews</div>
    <div class="svc-trust-sub">More than 30 years caring for patients in Benidorm</div>
  </div>
</section>

<!-- FLAGSHIP — INDIBA -->
<section class="svc-flagship">
  <div class="container">
    <div class="svc-flagship-grid">
      <div class="svc-flagship-img">
        <picture>
          <source srcset="{{ '/images/fotoscatalogoanylopez/radiofrecuenciacorporal.webp' | url }}" type="image/webp">
          <img
            src="{{ '/images/fotoscatalogoanylopez/radiofrecuenciacorporal.png' | url }}"
            alt="INDIBA radiofrequency at AnyLopez Benidorm"
            loading="lazy"
            decoding="async"
            width="800"
            height="1000"
          />
        </picture>
      </div>
      <div>
        <span class="eyebrow" style="color: var(--gold);">Flagship treatment</span>
        <h2>INDIBA Radiofrequency — <em>the lifting effect that doesn't show.</em></h2>
        <p>If you've cared for your skin all your life but the mirror keeps showing laxity, INDIBA is the answer without surgery. CRet/RES technology that stimulates your own collagen from the very first session. Painless, no recovery time, compatible with every other treatment.</p>
        <div class="svc-flagship-meta">
          <div class="svc-flagship-meta-item">
            <strong>€350</strong>
            10-session pack
          </div>
          <div class="svc-flagship-meta-item">
            <strong>€525</strong>
            Saving vs single session
          </div>
          <div class="svc-flagship-meta-item">
            <strong>1st session</strong>
            Visible results
          </div>
        </div>
        <a href="{{ '/en/radiofrecuencia/' | url }}" class="btn btn-accent">Discover INDIBA →</a>
      </div>
    </div>
  </div>
</section>

<!-- FINAL CTA -->
<section class="svc-final-cta">
  <div class="container">
    <span class="eyebrow">Not sure where to start?</span>
    <h2>Book a free assessment and we'll tell you what you need — and what you don't.</h2>
    <p>Thirty minutes, no commitment. If it's not for you, we'll say so straight up and point you in the right direction. Honesty before the basket.</p>
    <div class="svc-final-cta-row">
      <a href="{{ '/en/contact/' | url }}" class="btn btn-accent">Book your assessment →</a>
      <a href="https://wa.me/34656306167" class="btn btn-outline" target="_blank" rel="noopener noreferrer">WhatsApp 656 306 167</a>
    </div>
  </div>
</section>

<!-- JSON-LD: ItemList of categories -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "AnyLopez Aesthetic Clinic specialities",
  "numberOfItems": {{ en.tratamientos.categorias | length }},
  "itemListElement": [
    {%- for cat in en.tratamientos.categorias -%}
    {
      "@type": "ListItem",
      "position": {{ loop.index }},
      "item": {
        "@type": "MedicalSpecialty",
        "name": {{ cat.nombre | dump | safe }},
        "description": {{ cat.descripcion | dump | safe }},
        "url": "{{ site.url }}/en/services/{{ cat.id }}/"
      }
    }{% if not loop.last %},{% endif %}
    {%- endfor %}
  ]
}
</script>
