<script>
  /* ── Mapa Google: click-to-load (sin iframe en HTML inicial) ── */
  (function() {
    var ph = document.querySelector('.donde-map-placeholder');
    if (!ph) return;
    function loadMap() {
      var iframe = document.createElement('iframe');
      iframe.src = ph.dataset.mapSrc;
      iframe.className = 'donde-map';
      iframe.title = ph.dataset.mapTitle || '';
      iframe.allowFullscreen = true;
      iframe.referrerPolicy = 'no-referrer-when-downgrade';
      iframe.loading = 'lazy';
      ph.replaceWith(iframe);
    }
    ph.addEventListener('click', loadMap);
  })();

  /* ── Donde form AJAX ── */
  const dondeForm = document.getElementById('dondeForm');
  if (dondeForm) {
    dondeForm.addEventListener('submit', function(e) {
      e.preventDefault();
      const btn = dondeForm.querySelector('button[type="submit"]');
      btn.disabled = true;
      btn.textContent = 'Sending...';
      fetch(dondeForm.action, {
        method: 'POST',
        body: new FormData(dondeForm),
        headers: { 'Accept': 'application/json' }
      }).then(r => {
        if (r.ok) {
          dondeForm.style.display = 'none';
          document.getElementById('dondeFormSuccess').style.display = 'block';
        } else {
          btn.disabled = false;
          btn.textContent = 'Send message';
        }
      }).catch(() => {
        btn.disabled = false;
        btn.textContent = 'Send message';
      });
    });
  }

  /* ── Lead form AJAX ── */
  const leadForm = document.getElementById('leadForm');
  const leadMsg  = document.getElementById('leadFormMsg');
  if (leadForm) {
    leadForm.addEventListener('submit', function(e) {
      e.preventDefault();
      const btn = leadForm.querySelector('button[type="submit"]');
      btn.disabled = true;
      btn.textContent = 'Sending...';
      fetch(leadForm.action, {
        method: 'POST',
        body: new FormData(leadForm),
        headers: { 'Accept': 'application/json' }
      }).then(r => {
        if (r.ok) {
          leadForm.style.display = 'none';
          leadMsg.style.display = 'block';
        } else {
          btn.disabled = false;
          btn.textContent = 'Book appointment';
          alert('Error sending. Please call us on 656 306 167.');
        }
      }).catch(() => {
        btn.disabled = false;
        btn.textContent = 'Book appointment';
        alert('Error sending. Please call us on 656 306 167.');
      });
    });
  }


</script>
