            decoding="async"
            width="540"
            height="220"
          />
        </picture>
        <div class="trat-card-body">
          <h3 class="trat-card-name">{{ trat.nombre }}</h3>
          <p class="trat-card-desc">{{ trat.descripcion }}</p>

          {% if trat.incluye %}
          <ul class="trat-card-incluye">
            {% for item in trat.incluye %}
              {% if loop.index <= 3 %}
              <li>{{ item }}</li>
              {% endif %}
            {% endfor %}
          </ul>
          {% endif %}

          <div class="trat-card-meta">
            <span class="trat-duracion">
              <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
              </svg>
              {{ trat.duracion }}
            </span>
            <button
              type="button"
              class="trat-cta trat-card-trigger"
              data-slug="{{ trat.slug }}"
              aria-label="View details of {{ trat.nombre }}"
            >View details →</button>
          </div>
        </div>
      </article>
      {% endfor %}
    </div>
  </div>
</section>

