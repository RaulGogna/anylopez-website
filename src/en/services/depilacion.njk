  "mainEntity": [
    { "@type": "Question", "name": "How many sessions will I need?", "acceptedAnswer": { "@type": "Answer", "text": "Between 6 and 10 sessions, spaced according to the area and hair growth cycle. Face and underarms: every 4-6 weeks. Legs and body: every 6-8 weeks. A one-off top-up once a year after completing the plan." } },
    { "@type": "Question", "name": "Does it hurt?", "acceptedAnswer": { "@type": "Answer", "text": "A brief snapping sensation with each light pulse. Far more comfortable than hot wax or diode laser. Most people don't need any anaesthetic." } },
    { "@type": "Question", "name": "Can I have IPL in summer?", "acceptedAnswer": { "@type": "Answer", "text": "Ideally IPL is done outside periods of intense sun exposure. Summer is fine if your skin isn't tanned and you use strict sunscreen. For tanned skin it's better to wait until autumn or winter." } },
    { "@type": "Question", "name": "What about pregnancy or breastfeeding?", "acceptedAnswer": { "@type": "Answer", "text": "IPL isn't validated for pregnancy or breastfeeding as a precaution, even though there is no evidence of harm. We wait until breastfeeding ends before starting a plan." } },
    { "@type": "Question", "name": "IPL vs diode laser?", "acceptedAnswer": { "@type": "Answer", "text": "Both reduce hair permanently. IPL uses broad-spectrum pulsed light (more flexible across different areas and skin types). Diode laser uses a single coherent wavelength (more effective on very dark hair and fair skin, but less versatile)." } }
  ]
}
