  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Which modality for what?", "acceptedAnswer": { "@type": "Answer", "text": "Cervical tension/headaches: cranio-facial-cervical. Heavy legs: tired legs or aloe vera. Tired feet or reflex issues: reflexology. General anti-fatigue: body or relaxing. Deep facial care: collagen or vitamin C facial." } },
    { "@type": "Question", "name": "Ideal frequency?", "acceptedAnswer": { "@type": "Answer", "text": "Depends on the goal. General maintenance: once a month. Chronic tension: every 2-3 weeks until resolved. Facials: every 4-6 weeks combined with cleansing." } },
    { "@type": "Question", "name": "Cranio-facial-cervical massage for migraines?", "acceptedAnswer": { "@type": "Answer", "text": "Yes, particularly useful for tension headaches and migraines originating in the cervical area. It does not replace medical treatment but complements it significantly." } },
    { "@type": "Question", "name": "Pregnancy?", "acceptedAnswer": { "@type": "Answer", "text": "Yes, with adapted modality and position. A relaxing massage with a gentle technique is perfectly safe. Avoid reflex points on the feet during the first trimester." } },
    { "@type": "Question", "name": "What is reflexology massage and why reflexological?", "acceptedAnswer": { "@type": "Answer", "text": "The foot has zones that mirror organs of the body. Stimulating these zones with the right technique can ease distant tensions (headache, digestive fatigue, lower back pain). More than a foot massage — it is whole-body work." } }
  ]
}
</script>

