<!-- JSON-LD: ItemList of treatments linked to the MedicalClinic schema -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Catálogo de tratamientos AnyLopez",
  "numberOfItems": {{ tratamientos.tratamientos | length }},
  "itemListElement": [
    {%- for trat in tratamientos.tratamientos -%}
    {%- set idx = trat.packDestacado or 0 -%}
    {%- set priceClean = trat.precios[idx].precio | replace(' €','') | replace('Desde ','') | replace('.','') | trim -%}
    {
      "@type": "ListItem",
      "position": {{ loop.index }},
      "item": {
        "@type": ["MedicalProcedure", "Service"],
        "name": {{ trat.nombre | dump | safe }},
        "description": {{ trat.descripcion | dump | safe }},
        "url": "https://raulgogna.github.io/anylopez-website/services/#{{ trat.slug }}",
        "procedureType": "https://schema.org/NoninvasiveProcedure",
        "serviceType": {{ trat.nombre | dump | safe }},
        "provider": { "@id": "https://raulgogna.github.io/anylopez-website/#clinic" },
        "offers": {
          "@type": "Offer",
          "price": "{{ priceClean }}",
          "priceCurrency": "EUR",
          "availability": "https://schema.org/InStock",
          "url": "https://raulgogna.github.io/anylopez-website/services/#{{ trat.slug }}"
        }
      }
    }{% if not loop.last %},{% endif %}
    {%- endfor %}
  ]
}
</script>

<script>
  /* Active pill highlight on scroll */
  (function () {
    const pills = document.querySelectorAll('.cat-nav-pill');
    const sections = Array.from(document.querySelectorAll('.cat-section'));
    if (!pills.length || !sections.length) return;

    const navInner = document.querySelector('.cat-nav-inner');

    function setActivePill(id) {
      pills.forEach((p) => {
        const isActive = p.getAttribute('href') === '#' + id;
        p.classList.toggle('active', isActive);
        if (isActive && navInner) {
          p.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
        }
      });
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) setActivePill(entry.target.id);
        });
      },
      { rootMargin: '-30% 0px -60% 0px' }
    );
    sections.forEach((s) => observer.observe(s));

    if (navInner) {
      navInner.addEventListener('wheel', (e) => {
        if (e.deltaY !== 0) {
          e.preventDefault();
          navInner.scrollLeft += e.deltaY;
        }
      }, { passive: false });
    }

    pills.forEach((pill) => {
      pill.addEventListener('click', (e) => {
        e.preventDefault();
        const target = document.querySelector(pill.getAttribute('href'));
        if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    });
  })();
</script>
