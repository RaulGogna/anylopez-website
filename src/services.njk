---
layout: base.njk
title: "Tratamientos Estéticos en Benidorm — AnyLopez Clínica Estética"
description: "Catálogo completo de tratamientos de AnyLopez Clínica Estética en Benidorm: faciales, corporales, inyectables, masajes, depilación IPL y mucho más."
---

<style>
  /* ─── CATEGORY NAV ─────────────────────────────────────────────── */
  .cat-nav {
    position: sticky;
    top: 88px; /* --header-h V3 */
    z-index: 100;
    background: #fff;
    border-bottom: 1px solid var(--bg-light);
    padding: 0;
  }
  /* fade derecho para indicar que hay más pills */
  .cat-nav::after {
    content: '';
    position: absolute;
    right: 0;
    top: 0;
    bottom: 0;
    width: 48px;
    background: linear-gradient(to right, transparent, #fff);
    pointer-events: none;
    z-index: 1;
  }
  .cat-nav-inner {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding: 12px 48px 12px 24px; /* padding-right amplio para no quedar bajo el fade */
    max-width: 1200px;
    margin: 0 auto;
  }
  .cat-nav-inner::-webkit-scrollbar { display: none; }
  .cat-nav-pills {
    display: flex;
    gap: 8px;
    white-space: nowrap;
  }
  .cat-nav-pill {
    display: inline-block;
    padding: 6px 16px;
    border: 1.5px solid var(--bg-light);
    border-radius: 40px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.5px;
    color: var(--text-mid);
    text-decoration: none;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
    flex-shrink: 0;
  }
  .cat-nav-pill:hover,
  .cat-nav-pill.active {
    background: var(--primary);
    color: #fff;
    border-color: var(--primary);
  }

  /* ─── CATEGORY SECTION ─────────────────────────────────────────── */
  .cat-section {
    padding: 64px 0 80px;
    scroll-margin-top: 150px; /* header(88) + cat-nav(~58) + 4px */
  }
  .cat-section:nth-child(even) { background: var(--bg-cream); }
  .cat-header {
    margin-bottom: 48px;
  }
  .cat-header .section-label { margin-bottom: 8px; }
  .cat-header h2 { font-size: clamp(24px, 4vw, 36px); margin-bottom: 10px; }
  .cat-header p { color: var(--text-mid); font-size: 15px; max-width: 560px; }

  /* ─── CATEGORY VISUAL BANNER ───────────────────────────────────── */
  .cat-visual {
    width: 100%;
    height: 260px;
    overflow: hidden;
    border-radius: 8px;
    margin-bottom: 32px;
    position: relative;
  }
  .cat-visual img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .cat-visual::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, rgba(28,26,24,0.35) 0%, transparent 60%);
    border-radius: 8px;
  }

  /* ─── TREATMENT GRID ────────────────────────────────────────────── */
  .trat-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }

  /* ─── TREATMENT CARD ────────────────────────────────────────────── */
  .trat-card {
    background: #fff;
    border-radius: 4px;
    overflow: hidden;
    box-shadow: var(--shadow);
    display: flex;
    flex-direction: column;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .trat-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(28,26,24,.14);
  }
  .trat-card-img {
    width: 100%;
    height: 200px;
    object-fit: cover;
    display: block;
    background: var(--bg-light);
  }
  .trat-card--bare {
    border-top: 3px solid var(--accent);
  }
  .trat-card-body {
    padding: 24px;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .trat-card-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 18px;
    line-height: 1.3;
    color: var(--primary);
    margin: 0;
  }
  .trat-card-desc {
    font-size: 13px;
    line-height: 1.65;
    color: var(--text-mid);
    margin: 0;
  }
  .trat-card-incluye {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .trat-card-incluye li {
    font-size: 12px;
    color: var(--text-mid);
    padding-left: 14px;
    position: relative;
    line-height: 1.5;
  }
  .trat-card-incluye li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--accent);
    font-weight: 700;
    font-size: 11px;
  }
  .trat-card-meta {
    margin-top: auto;
    padding-top: 16px;
    border-top: 1px solid var(--bg-light);
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .trat-duracion {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.5px;
    color: var(--text-mid);
    text-transform: uppercase;
  }
  .trat-duracion svg {
    width: 13px;
    height: 13px;
    flex-shrink: 0;
    stroke: var(--accent);
  }
  .trat-cta {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--accent);
    text-decoration: none;
    transition: color 0.2s;
  }
  .trat-cta:hover { color: var(--primary); }

  /* ─── RESPONSIVE ────────────────────────────────────────────────── */
  @media (max-width: 1024px) {
    .trat-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .trat-grid { grid-template-columns: 1fr; }
    .cat-section { padding: 48px 0 64px; }
    .cat-header { margin-bottom: 32px; }
    .cat-visual { height: 180px; }
  }
</style>

