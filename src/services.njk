<!-- TREATMENT CATEGORIES -->
{% for cat in tratamientos.categorias %}
{% set catTrats = tratamientos.tratamientos | byCategory(cat.id) %}
<section class="cat-section" id="{{ cat.id }}">
  <div class="container">
    <div class="cat-header">
      <span class="section-label">{{ loop.index }} / {{ tratamientos.categorias | length }}</span>
      <h2>{{ cat.nombre }}</h2>
      <p>{{ cat.descripcion }}</p>
    </div>

    {% set catSharedImage = catTrats | length > 1 and catTrats[0].imagen == catTrats[1].imagen %}
    {% if catSharedImage %}
    {% set catImg0 = catTrats[0].imagen %}
    <div class="cat-visual">
      <picture>
        <source srcset="{{ ('/images/tratamientos/' + catImg0.replace('.png', '.webp')) | url }}" type="image/webp">
        <img src="{{ ('/images/tratamientos/' + catImg0) | url }}" alt="{{ cat.nombre }}" loading="lazy" decoding="async" />
      </picture>
    </div>
    {% endif %}

    <div class="trat-grid">
      {% for trat in catTrats %}
      <article class="trat-card{% if catSharedImage %} trat-card--bare{% endif %}" data-slug="{{ trat.slug }}">
        {% if not catSharedImage %}
        <picture>
          <source srcset="{{ ('/images/tratamientos/' + trat.imagen.replace('.png', '.webp')) | url }}" type="image/webp">
          <img
            src="{{ ('/images/tratamientos/' + trat.imagen) | url }}"
            alt="{{ trat.nombre }}"
            class="trat-card-img"
            loading="lazy"
            decoding="async"
            width="400"
            height="200"
          />
        </picture>
        {% endif %}
        <div class="trat-card-body">
          <h3 class="trat-card-name">{{ trat.nombre }}</h3>
          <p class="trat-card-desc">{{ trat.descripcion }}</p>

          {% if trat.incluye %}
          <ul class="trat-card-incluye">
            {% for item in trat.incluye %}
            <li>{{ item }}</li>
            {% endfor %}
          </ul>
          {% endif %}

          <div class="trat-card-meta">
            <span class="trat-duracion">
              <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
              </svg>
              {{ trat.duracion }}
            </span>
            <button
              type="button"
              class="trat-cta trat-card-trigger"
              data-slug="{{ trat.slug }}"
              aria-label="Ver detalles de {{ trat.nombre }}"
            >Ver detalles →</button>
          </div>
        </div>
      </article>
      {% endfor %}
    </div>
  </div>
</section>
{% endfor %}

